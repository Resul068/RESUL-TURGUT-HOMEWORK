"""
Pseudocode:
1. Initialize an empty list called 'scores' to store the grades.
2. Use a 'for' loop to ask for input 5 times.
3. In each iteration, convert input to float and append it to the list.
4. Calculate the average by dividing the sum of the list by its length.
5. Use if/elif/else conditions to assign a letter grade based on the average.
6. Print the final average and the letter grade.
"""

scores = []

# Collect 5 subject scores using a loop
for i in range(5):
    score = float(input(f"Enter score {i + 1}: "))
    scores.append(score)

# Step 1 — Calculate the average
# sum(scores) adds everything in the list, len(scores) is the count (5)
average = sum(scores) / len(scores)

# Step 2 — Determine the grade using if/elif/else
if average >= 90:
    grade = "A"
elif average >= 80:
    grade = "B"
elif average >= 70:
    grade = "C"
elif average >= 60:
    grade = "D"
else:
    grade = "F"

# Step 3 — Print the results
print(f"Average: {average:.1f}")
print(f"Grade: {grade}")
