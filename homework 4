"""
Pseudocode:
1. Get a sentence input from the user.
2. Convert the sentence to lowercase and split it into a list of words.
3. Calculate total words using len().
4. Calculate total characters by removing spaces.
5. Create a dictionary to store the count of each unique word.
6. Loop through the words: if the word exists in the dictionary, increment its count; 
   if not, add it with a value of 1.
7. Print the results clearly.
"""

sentence = input("Enter a sentence: ")

# Step 1 — Split into a list of lowercase words
words = sentence.lower().split()

# Step 2 — Count total words
total_words = len(words)

# Step 3 — Count total characters (excluding spaces)
# We replace spaces with empty strings to count only the letters/symbols
total_chars = len(sentence.replace(" ", ""))

# Step 4 — Build a word frequency dictionary
frequency = {}
for word in words:
    if word in frequency:
        frequency[word] += 1  # Key exists, increment the value
    else:
        frequency[word] = 1   # Key doesn't exist, create it with 1

# Step 5 — Print all results
print(f"Total words: {total_words}")
print(f"Total characters (no spaces): {total_chars}")
print("Word frequency:")

for word, count in frequency.items():
    print(f"  {word} -> {count}")
