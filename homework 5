"""
Pseudocode:
1. Define a menu dictionary where keys are numbers and values are tuples (item name, price).
2. Initialize an empty cart dictionary and a total price variable.
3. Start an infinite loop to display the menu and get user choices.
4. If the user picks an item (1-4):
   - Update the running total.
   - Update the cart dictionary (increment quantity if item exists, else add it).
5. If the user picks 5, break the loop.
6. Print a formatted receipt showing names, quantities, and the final total.
"""

menu = {
    1: ("Apple",  0.50),
    2: ("Banana", 0.30),
    3: ("Milk",   1.20),
    4: ("Bread",  2.00),
}

cart  = {}   # Stores { item_name: quantity }
total = 0.0

print("--- Shop Menu ---")
for key, value in menu.items():
    print(f"{key}. {value[0]:<8} ${value[1]:.2f}")
print("5. Done")

while True:
    choice = input("\nChoose an item (1-5): ")
    
    # Check if input is a valid number
    if not choice.isdigit():
        print("Invalid input! Please enter a number.")
        continue
        
    choice = int(choice)

    if choice == 5:
        break
    
    if choice in menu:
        item_name, price = menu[choice]
        total += price
        
        # Track quantities for the receipt
        if item_name in cart:
            cart[item_name] += 1
        else:
            cart[item_name] = 1
            
        print(f"Added {item_name}. Total: ${total:.2f}")
    else:
        print("Invalid choice! Please select 1-5.")

# --- Receipt Printing ---
print("\n--- Receipt ---")
for item, qty in cart.items():
    # Find the price of the item from the menu to show in the receipt
    # We find it by matching the name
    for m_id in menu:
        if menu[m_id][0] == item:
            item_price = menu[m_id][1]
            break
            
    print(f"{item:<8} x{qty}   ${item_price * qty:.2f}")

print("-" * 21)
print(f"Total: ${total:.2f}")
print("Thank you!")
if total > 5.00:
    discount = total * 0.10
    total -= discount
    print(f"Discount applied: -${discount:.2f}")
